{
  "expo": {
    "name": "LIFECODE",
    "slug": "lifecode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifecode",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifecode.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fafaf7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.lifecode.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fafaf7",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LIFECODE needs photo access to log meals you scan.",
          "cameraPermission": "LIFECODE needs camera access to scan meals and nutrition labels."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
